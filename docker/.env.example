# Copy this file to .env and edit. docker compose auto-loads .env in this dir.
#   cp .env.example .env

# ── Embedded services (default: PostgreSQL + Redis both bundled in compose) ──
# COMPOSE_PROFILES is a built-in docker-compose variable that activates the
# named profiles in this file's services. Set it here so you never need to
# pass --profile flags on the command line.
#
# Examples:
#   COMPOSE_PROFILES=with-postgres,with-redis    (default — both embedded)
#   COMPOSE_PROFILES=with-redis                  (use external PG, embedded Redis)
#   COMPOSE_PROFILES=with-postgres               (embedded PG, external Redis)
#   COMPOSE_PROFILES=                            (both external — typical production)
#
# When you exclude a profile, fill in the corresponding URL below.
COMPOSE_PROFILES=with-postgres,with-redis

# ── Image version ────────────────────────────────────────────────────────
OPENDESK_VERSION=latest

# ── Database ─────────────────────────────────────────────────────────────
# Required ONLY when "with-postgres" is removed from COMPOSE_PROFILES above.
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
#DATABASE_URL=

# Embedded postgres credentials (only used when "with-postgres" is active)
POSTGRES_USER=opendesk
POSTGRES_PASSWORD=opendesk
POSTGRES_DB=opendesk

# ── Redis ────────────────────────────────────────────────────────────────
# Required ONLY when "with-redis" is removed from COMPOSE_PROFILES above.
# Format: redis://[:PASSWORD@]HOST:6379/DB
#REDIS_URL=

# ── Auth (required) ──────────────────────────────────────────────────────
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── First-run defaults (only used when tenants table is empty) ───────────
DEFAULT_TENANT_ID=default
DEFAULT_TENANT_NAME=Default Workspace
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin123456

# ── Ports (host:container) ───────────────────────────────────────────────
API_PORT=5001
WEB_PORT=3000

# ── Frontend (browser reads these — set to public hostname in production) ──
PUBLIC_API_URL=http://localhost:5001/api/
PUBLIC_SOCKET_URL=http://localhost:5001

# ── Email (optional) ─────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Object storage (optional, for file uploads) ──────────────────────────
# Currently only aliyun_oss is implemented.
STORAGE_PROVIDER=aliyun_oss
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_ADDR=
OSS_URL=
OSS_BUCKET=
