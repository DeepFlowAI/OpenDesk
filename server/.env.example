# ─── App ──────────────────────────────────────────────────────────────────
APP_NAME=OpenDesk
APP_VERSION=0.1.0
DEBUG=false
# Console log format: 'text' (human-readable) or 'json' (one object per line).
LOG_FORMAT=text

# ─── Database (PostgreSQL 15+) ────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://opendesk:change-me@localhost:5432/opendesk
# Run `alembic upgrade head` on app startup. Disable for read-replica processes.
AUTO_MIGRATE=true

# ─── Redis 7.0+ ───────────────────────────────────────────────────────────
# Format: redis://[:PASSWORD@]HOST:PORT/DB
REDIS_URL=redis://localhost:6379/0

# ─── Message Queue / Realtime ─────────────────────────────────────────────
MESSAGE_QUEUE_PROVIDER=redis_streams
REALTIME_PROVIDER=socketio
SOCKETIO_PING_INTERVAL=25
SOCKETIO_PING_TIMEOUT=60
AGENT_OFFLINE_GRACE_SECONDS=30

# ─── Auth / JWT ───────────────────────────────────────────────────────────
# IMPORTANT: generate with `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=change-me-to-a-32-byte-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ─── Public Chat / Bot Timeouts ──────────────────────────────────────────────
VISITOR_SESSION_EXPIRE_SECONDS=86400
OPEN_AGENT_BOT_TIMEOUT_WORKER_ENABLED=true
OPEN_AGENT_BOT_TIMEOUT_SECONDS=3600
OPEN_AGENT_BOT_TIMEOUT_SCAN_INTERVAL_SECONDS=60
OPEN_AGENT_BOT_TIMEOUT_SCAN_BATCH_SIZE=100

# ─── Email (SMTP, optional) ───────────────────────────────────────────────
# Used for password reset and verification codes. Leave empty to disable.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

VERIFY_CODE_EXPIRE_SECONDS=600
VERIFY_CODE_COOLDOWN_SECONDS=60

# ─── Default Tenant (auto-provisioned on first startup) ──────────────────
# When the tenants table is empty, the seed step creates ONE tenant + one
# super-admin employee using these values. Once any tenant exists this is
# a no-op forever, so changing these later has no effect.
# Open-source users log in with: tenant=DEFAULT_TENANT_ID, then change the
# password right after the first login.
DEFAULT_TENANT_ID=default
DEFAULT_TENANT_NAME=Default Workspace
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin123456

# ─── Tenant Platform API Key ──────────────────────────────────────────────
# Optional. Consumed by tenant-management extensions registered via the
# extension loader (see `app/extensions/`). The default single-tenant build
# does not read this value. If you wire up a custom extension that does,
# generate a secret with:
#   echo "sk-$(python -c 'import secrets; print(secrets.token_hex(20))')"
TENANT_API_KEY=sk-change-me

# ─── Knowledge Recommendation Embeddings ─────────────────────────────────
# Uses Aliyun DashScope text-embedding-v4 through the OpenAI-compatible
# embeddings endpoint. Leave the API key empty to keep recommendation vectors
# disabled until you configure a provider credential.
KNOWLEDGE_EMBEDDING_PROVIDER=aliyun
KNOWLEDGE_EMBEDDING_MODEL=text-embedding-v4
KNOWLEDGE_EMBEDDING_DIMENSION=1024
KNOWLEDGE_EMBEDDING_TIMEOUT_SECONDS=30
KNOWLEDGE_EMBEDDING_TEXT_MAX_CHARS=6000
KNOWLEDGE_RECOMMENDATION_LIMIT=20
ALIYUN_DASHSCOPE_API_KEY=
ALIYUN_DASHSCOPE_EMBEDDING_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings

# ─── Object Storage ───────────────────────────────────────────────────────
# Currently only aliyun_oss is implemented. Leave OSS_* empty to disable uploads.
STORAGE_PROVIDER=aliyun_oss
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
# Public URL prefix (used as the source of returned media URLs).
OSS_ADDR=
# OSS service endpoint.
OSS_URL=
OSS_BUCKET=

# ─── Call Center / Telephony ──────────────────────────────────────────────
# The call-center module is OFF by default in OSS builds because it needs
# an external telephony kernel. Enable it after you set the variables below.
CALL_CENTER_ENABLED=false

# Telephony provider implementations live in app/libs/telephony/providers/.
#   mock    — in-process stub for local dev / tests (no external calls)
#   flowkit — JSON-RPC over WebSocket to a FlowKit kernel (production)
TELEPHONY_PROVIDER=mock

# Required when TELEPHONY_PROVIDER=flowkit. Format: ws://host:port/ws (or wss://).
# Obtain the URL from your telephony platform operator; do NOT commit a real
# value to source control.
TELEPHONY_WS_URL=

# Identifier the orchestrator sends in the JSON-RPC system.hello handshake.
TELEPHONY_SDK_NAME=opendesk-cc
TELEPHONY_SDK_VERSION=1.0.0

# RPC timeout in seconds for a single call_xxx request.
TELEPHONY_RPC_TIMEOUT=30

# ─── Observability (optional, OTLP/OpenTelemetry) ─────────────────────────
# Ships every stdlib log record to an OTLP-compatible backend (GreptimeDB,
# SigNoz, Honeycomb, Tempo, a self-hosted collector …). Default "noop" keeps
# logs on stdout only and adds zero overhead — OTel packages aren't even
# imported. Set to "otel" and fill the OTEL_* vars to enable shipping.
OBSERVABILITY_BACKEND=noop
# Identity stamped on every log/span resource_attributes.
OTEL_SERVICE_NAME=opendesk-api
OTEL_DEPLOYMENT_ENVIRONMENT=dev
# OTLP/HTTP endpoint, e.g. http://collector-host:4318 (no trailing path).
OTEL_EXPORTER_OTLP_ENDPOINT=
# Comma-separated "k=v,k=v", e.g. Authorization=Basic <base64(user:pass)>.
OTEL_EXPORTER_OTLP_HEADERS=
# GreptimeDB-specific extras (harmless to other backends; leave as-is or blank).
OTEL_TRACES_PIPELINE_NAME=greptime_trace_v1
OTEL_LOGS_TABLE_NAME=otel_logs
